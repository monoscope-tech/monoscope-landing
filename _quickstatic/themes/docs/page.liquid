    <script defer type="text/javascript">
      document.addEventListener('DOMContentLoaded', function () {
        hljs.highlightAll();
      });

      function initCodeBlocks() {
        document.querySelectorAll('#mainArticle pre > code').forEach(function(code) {
          var pre = code.parentElement;
          if (pre.querySelector('.code-header')) return;
          var lang = '';
          code.classList.forEach(function(c) {
            if (c.startsWith('language-')) lang = c.replace('language-', '');
          });
          if (lang === 'html' && code.closest('[class*="=html"]')) return;
          var header = document.createElement('div');
          header.className = 'code-header';
          header.innerHTML = '<span class="code-lang" data-lang="' + (lang || 'code') + '">' + (lang || 'code') + '</span>' +
            '<button class="code-copy" title="Copy code"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg><span>Copy</span></button>';
          header.querySelector('.code-copy').addEventListener('click', function() {
            var btn = this;
            navigator.clipboard.writeText(code.textContent).then(function() {
              btn.classList.add('copied');
              btn.querySelector('span').textContent = 'Copied!';
              setTimeout(function() {
                btn.classList.remove('copied');
                btn.querySelector('span').textContent = 'Copy';
              }, 2000);
            });
          });
          pre.insertBefore(header, code);
        });
      }

      function initSidebarState() {
        // No localStorage — always trust server-rendered open state
        // (current section auto-opens via Liquid template logic)
      }

      function initPrevNext() {
        var nav = document.getElementById('prev-next-nav');
        if (!nav) return;
        var links = Array.from(document.querySelectorAll('#sidebar-nav a[href]'));
        var current = window.location.pathname.replace(/\/$/, '');
        var idx = links.findIndex(function(a) { return a.getAttribute('href').replace(/\/$/, '') === current; });
        if (idx === -1) return;
        var html = '';
        if (idx > 0) {
          html += '<a class="prev-next-card prev" href="' + links[idx-1].getAttribute('href') + '">' +
            '<span class="direction">&larr; Previous</span>' +
            '<span class="title">' + links[idx-1].textContent.trim() + '</span></a>';
        }
        if (idx < links.length - 1) {
          html += '<a class="prev-next-card next" href="' + links[idx+1].getAttribute('href') + '">' +
            '<span class="direction">Next &rarr;</span>' +
            '<span class="title">' + links[idx+1].textContent.trim() + '</span></a>';
        }
        nav.innerHTML = html;
      }

      var docsAIConfig = {
        mcpServerUrl: '',
        siteName: 'Monoscope Docs'
      };

      function initAIMenu() {
        var trigger = document.getElementById('ai-menu-trigger');
        var menu = document.getElementById('ai-menu');
        if (!trigger || !menu) return;

        // Enable/disable MCP items
        var mcpItems = menu.querySelectorAll('[data-action="copy-mcp"],[data-action="connect-cursor"],[data-action="connect-vscode"]');
        mcpItems.forEach(function(el) {
          el.classList.toggle('disabled', !docsAIConfig.mcpServerUrl);
        });

        // Set AI assistant hrefs
        var pageUrl = window.location.href;
        var title = document.querySelector('#mainArticle h1');
        var pageTitle = title ? title.textContent.replace(/#/g, '').trim() : document.title;
        var prompt = 'Read this ' + docsAIConfig.siteName + ' page and help me understand it: ' + pageUrl;

        var chatgpt = menu.querySelector('[data-action="open-chatgpt"]');
        if (chatgpt) chatgpt.href = 'https://chatgpt.com/?hints=search&q=' + encodeURIComponent(prompt);

        var claude = menu.querySelector('[data-action="open-claude"]');
        if (claude) claude.href = 'https://claude.ai/new?q=' + encodeURIComponent(prompt);

        var perplexity = menu.querySelector('[data-action="open-perplexity"]');
        if (perplexity) perplexity.href = 'https://www.perplexity.ai/search?q=' + encodeURIComponent(prompt);

        // MCP deep links
        if (docsAIConfig.mcpServerUrl) {
          var cursorLink = menu.querySelector('[data-action="connect-cursor"]');
          if (cursorLink) cursorLink.href = 'cursor://anysphere.cursor-deeplink/mcp/install?name=monoscope-docs&url=' + encodeURIComponent(docsAIConfig.mcpServerUrl);
          var vscodeLink = menu.querySelector('[data-action="connect-vscode"]');
          if (vscodeLink) vscodeLink.href = 'vscode://anysphere.cursor-deeplink/mcp/install?name=monoscope-docs&url=' + encodeURIComponent(docsAIConfig.mcpServerUrl);
        }

        // Toggle
        trigger.onclick = function(e) {
          e.stopPropagation();
          menu.classList.toggle('open');
        };

        // Close on outside click
        document.addEventListener('click', function(e) {
          if (!menu.contains(e.target) && e.target !== trigger) menu.classList.remove('open');
        });

        // Close on Escape
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') menu.classList.remove('open');
        });

        function getPageMarkdown() {
          var article = document.getElementById('mainArticle');
          if (!article) return '';
          var clone = article.cloneNode(true);
          // Remove breadcrumbs/AI menu wrapper, prev/next nav, code headers
          clone.querySelectorAll('.breadcrumbs, .ai-menu-wrap, .code-header, #prev-next-nav').forEach(function(el) { el.remove(); });
          // Remove the flex wrapper that contains breadcrumbs + AI button
          var flexWrap = clone.querySelector('.flex.items-center.justify-between');
          if (flexWrap) flexWrap.remove();
          return '# ' + pageTitle + '\n\nSource: ' + pageUrl + '\n\n' + clone.innerText;
        }

        // Copy page as markdown
        menu.querySelector('[data-action="copy-page"]').onclick = function() {
          var text = getPageMarkdown();
          if (!text) return;
          navigator.clipboard.writeText(text).then(function() { showCopied('copy-page'); });
        };

        // View as markdown in new tab
        menu.querySelector('[data-action="view-markdown"]').onclick = function() {
          var text = getPageMarkdown();
          if (!text) return;
          var blob = new Blob([text], { type: 'text/plain' });
          window.open(URL.createObjectURL(blob), '_blank');
        };

        // Copy MCP URL
        menu.querySelector('[data-action="copy-mcp"]').onclick = function() {
          if (!docsAIConfig.mcpServerUrl) return;
          navigator.clipboard.writeText(docsAIConfig.mcpServerUrl).then(function() { showCopied('copy-mcp'); });
        };

        function showCopied(action) {
          var item = menu.querySelector('[data-action="' + action + '"]');
          item.classList.add('copied');
          setTimeout(function() { item.classList.remove('copied'); }, 2000);
        }
      }

      function init() {
        var sel = '#mainArticle h1, #mainArticle h2, #mainArticle h3, #mainArticle h4, #mainArticle h5, #mainArticle h6';
        var headings = document.querySelectorAll(sel);

        headings.forEach(function(h) {
          var hid = h.id || (h.parentElement && h.parentElement.id) || '';
          if (!h.querySelector('.header-link') && hid) {
            var a = document.createElement('a');
            a.classList.add('header-link');
            a.textContent = '#';
            a.href = '#' + hid;
            h.insertBefore(a, h.firstChild);
          }
        });

        var tocLinks = document.querySelectorAll('#tableOfContents a');
        if (tocLinks.length) {
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                var eid = entry.target.id || (entry.target.parentElement && entry.target.parentElement.id) || '';
                if (!eid) return;
                tocLinks.forEach(function(l) { l.classList.remove('active'); });
                var match = document.querySelector('#tableOfContents a[href="#' + eid + '"]');
                if (match) match.classList.add('active');
              }
            });
          }, { rootMargin: '-80px 0px -80% 0px', threshold: 0 });

          headings.forEach(function(h) { observer.observe(h); });
        }

        initCodeBlocks();
        initSidebarState();
        initPrevNext();
        initCalloutColors();
        initAIMenu();
      }

      function initCalloutColors() {
        document.querySelectorAll('.callout').forEach(function(el) {
          if (el.classList.contains('callout-tip') || el.classList.contains('callout-red') || el.classList.contains('callout-warning')) return;
          var icon = el.querySelector('i.fa-lightbulb');
          if (icon) el.classList.add('callout-tip');
        });
      }

      function toggleFaq(e) {
        e.currentTarget.nextElementSibling.classList.toggle('hidden');
        e.currentTarget.firstElementChild.classList.toggle('rotate-90');
      }

      init();

      document.body.addEventListener('htmx:afterSettle', function () {
        requestAnimationFrame(function() {
          hljs.highlightAll();
          init();
        });
      });
    </script>
  </body>
</html>
