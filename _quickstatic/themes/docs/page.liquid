<!doctype html>
<html lang="en">
  <head>
    <title>
      {% if this.frontmatter.ogTitle %}
        {{ this.frontmatter.ogTitle }}
      {% else %}
        {{ this.frontmatter.title }}
      {% endif %}
      | Monoscope Docs
    </title>
    <meta name="description" content="Monoscope product and SDKs documentation">
    <link rel="canonical" href="https://monoscope.tech{{this.permalink}}">
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="generator" content="QuickStatic">
    <!-- This documentation site was built with QuickStatic, https://github.com/tonyalaribe/quickstatic -->
    <meta
      property="og:title"
      content="{% if this.frontmatter.ogTitle %}{{this.frontmatter.ogTitle}}{% else %}{{this.frontmatter.title}}{% endif %} | Monoscope Docs"
    >
    <meta property="og:description" content="Monoscope product and SDKs documentation">
    {% assign og_parts = this.permalink | split: '/' %}{% assign og_slug = '' %}{% for p in og_parts %}{% if p != '' %}{% if og_slug != '' %}{% assign og_slug = og_slug | append: '/' %}{% endif %}{% assign og_slug = og_slug | append: p %}{% endif %}{% endfor %}
    <meta
      property="og:image"
      content="{% if this.frontmatter.ogImage %}{{this.frontmatter.ogImage}}{% else %}https://monoscope.tech/assets/og/{{ og_slug }}.png{% endif %}"
    >
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="{% if this.frontmatter.ogImage %}{{this.frontmatter.ogImage}}{% else %}https://monoscope.tech/assets/og/{{ og_slug }}.png{% endif %}">
    <meta
      property="og:type"
      content="{% if this.frontmatter.ogType %}{{this.frontmatter.ogType}}{% else %}article{% endif %}"
    >

    <!-- Favicon items -->
    <link rel="apple-touch-icon" sizes="180x180" href="/static/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/static/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/static/favicon-16x16.png">
    <link rel="manifest" href="/static/site.webmanifest">
    <link rel="mask-icon" href="/static/safari-pinned-tab.svg" color="#5bbad5">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">
    <base href="{{ this.permalink }}">

    <!-- Stylesheets and Scripts -->
    <link rel="preload" href="/assets/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="/assets/css/tailwind.min.css" hx-preserve="true">
    <link rel="stylesheet" href="/assets/deps/fontawesome/css/all.min.css" hx-preserve="true">
    <script defer src="/assets/deps/htmx/htmx.min.js"></script>
    <script defer src="/assets/deps/htmx/idiomorph-ext.min.js"></script>
    <script defer src="/assets/deps/htmx/preload.js"></script>
    <script defer src="/assets/deps/htmx/head-support.js"></script>
    <style>
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 300 900;
        font-display: swap;
        src: url('/assets/fonts/inter-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 300 900;
        font-display: swap;
        src: url('/assets/fonts/inter-latin-ext.woff2') format('woff2');
        unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1D2B, U+1D6B-1D77, U+1D79-1DBE, U+1E00-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
      }

      body {
        font-family: Inter, "Inter Fallback", sans-serif;
      }

      html {
        scroll-behavior: auto;
      }
      
      /* Table of Contents Active State */
      #tableOfContents a.active {
        color: var(--color-textBrand-strong);
        border-left-color: var(--color-strokeBrand-strong);
        font-weight: 500;
        background-color: var(--color-fillBrand-weak);
        border-radius: 0 6px 6px 0;
      }
      
      /* Heading typography: weight hierarchy + tracking */
      #mainArticle h1,
      #mainArticle h2,
      #mainArticle h3,
      #mainArticle h4,
      #mainArticle h5,
      #mainArticle h6 {
        position: relative;
        cursor: pointer;
      }
      #mainArticle h1 {
        font-weight: 600;
        letter-spacing: -0.025em;
      }
      #mainArticle h2 {
        font-weight: 500;
        letter-spacing: -0.02em;
      }
      #mainArticle h3 {
        font-weight: 600;
        letter-spacing: -0.015em;
      }
      #mainArticle h4 {
        font-weight: 600;
        letter-spacing: -0.01em;
        text-transform: none;
      }
      #mainArticle h5,
      #mainArticle h6 {
        font-weight: 500;
      }
      /* ── Section rhythm: clear visual breaks between h2 sections ── */
      /* Every h2-level section gets generous top spacing */
      #mainArticle > section > section {
        padding-top: 2rem;
        margin-top: 1rem;
      }
      /* After the first two sections, add a divider line for stronger separation */
      #mainArticle > section > section + section + section > h2 {
        border-top: 1px solid var(--color-strokeWeak);
        padding-top: 2rem;
        margin-top: 0.5rem;
      }
      /* First section (intro/prerequisites) gets no extra top margin */
      #mainArticle > section > section:first-of-type {
        padding-top: 0;
        margin-top: 0;
      }

      /* ── Code block breathing room ── */
      #mainArticle pre {
        margin-top: 1.25em;
        margin-bottom: 1.5em;
      }

      /* ── Tighter paragraph spacing for denser, more scannable docs ── */
      #mainArticle p {
        margin-top: 1em;
        margin-bottom: 1em;
      }

      /* Reduce gap between heading and its first paragraph */
      #mainArticle h2 + p,
      #mainArticle h3 + p,
      #mainArticle h4 + p {
        margin-top: 0.5em;
      }

      /* h4 sub-sections: tighter internal rhythm */
      #mainArticle > section > section > section {
        margin-top: 1.5rem;
      }

      /* Slightly looser line-height on dark backgrounds for readability */
      [data-theme='dark'] #mainArticle p,
      [data-theme='dark'] #mainArticle li {
        line-height: 1.7;
      }

      /* Ensure list items match body text size */
      #mainArticle li {
        font-size: 1.125rem;
      }

      /* Tabular numbers for data tables */
      .docs-table table tbody tr td {
        font-variant-numeric: tabular-nums;
      }

      .header-link {
        position: absolute;
        left: -24px;
        top: 50%;
        transform: translateY(-50%);
        display: none;
        text-decoration: none;
        color: var(--color-textBrand-strong);
        cursor: pointer;
        font-size: 1rem;
        padding-right: 20px;
        opacity: 0.6;
        transition: opacity 0.2s ease;
      }

      .header-link:hover {
        opacity: 1;
      }

      h1:hover .header-link,
      h2:hover .header-link,
      h3:hover .header-link,
      h4:hover .header-link,
      h5:hover .header-link,
      h6:hover .header-link,
      .header-link:hover {
        display: inline;
      }

      .docs-card,
      .docs-card-2 {
        display: flex;
        flex-direction: column;
        width: 100%;
        min-width: 0;
        padding: 1.5rem;
        text-decoration: none;
        border: 1px solid var(--color-strokeWeak);
        background-color: var(--color-bgRaised);
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);
        transition: border-color 200ms ease, box-shadow 200ms ease;
        gap: 0.75rem;
        overflow: hidden;
      }

      .docs-card {
        justify-content: flex-start;
        align-items: flex-start;
      }

      .docs-card-2 {
        justify-content: center;
        align-items: center;
      }

      .docs-card:hover,
      .docs-card-2:hover {
        border-color: var(--color-strokeBrand-weak);
        box-shadow: 0 4px 12px 0 rgba(0, 0, 0, 0.08);
      }

      .docs-card:focus-visible,
      .docs-card-2:focus-visible {
        outline: 2px solid var(--color-strokeBrand-strong);
        outline-offset: 2px;
      }

      .docs-card p,
      .docs-card-2 p {
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .docs-card i,
      .docs-card-2 i {
        color: var(--color-fillBrand-strong);
      }

      .docs-card i {
        font-size: 1.5rem;
      }

      .docs-card-2 i {
        font-size: 2rem;
      }

      .docs-card > span,
      .docs-card-2 > span {
        color: var(--color-textWeak);
        line-height: 1.6;
        display: block;
        font-size: 0.875rem;
      }

      /* ── Unified docs grid: 2×N peer cells with internal dividers ── */
      .docs-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1px;
        background-color: var(--color-strokeWeak);
        border: 1px solid var(--color-strokeWeak);
        border-radius: 0.75rem;
        overflow: hidden;
      }
      @media (min-width: 640px) {
        .docs-grid { grid-template-columns: 1fr 1fr; }
      }
      .docs-grid__cell {
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
        padding: 1.5rem 1.75rem;
        background-color: var(--color-bgRaised);
        text-decoration: none;
        transition: background-color 200ms ease;
      }
      .docs-grid__cell:hover {
        background-color: var(--color-fillBrand-weak);
      }
      .docs-grid__cell:focus-visible {
        outline: 2px solid var(--color-strokeBrand-strong);
        outline-offset: -2px;
        position: relative;
        z-index: 1;
      }
      .docs-grid__cell p {
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1rem;
        color: var(--color-textStrong);
      }
      .docs-grid__cell i {
        color: var(--color-fillBrand-strong);
        font-size: 1.125rem;
      }
      .docs-grid__cell strong {
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      .docs-grid__cell > span {
        color: var(--color-textWeak);
        font-size: 0.9375rem;
        line-height: 1.55;
      }

      /* ── Surface chooser: asymmetric — primary surface featured ── */
      .surface-chooser {
        display: grid;
        gap: 1px;
        background-color: var(--color-strokeWeak);
        border: 1px solid var(--color-strokeWeak);
        border-radius: 0.75rem;
        overflow: hidden;
        margin: 1.75rem 0;
        grid-template-columns: 1.65fr 1fr;
        grid-template-rows: 1fr 1fr;
        grid-template-areas:
          "primary alt-a"
          "primary alt-b";
      }
      @media (max-width: 640px) {
        .surface-chooser {
          grid-template-columns: 1fr;
          grid-template-rows: auto;
          grid-template-areas: none;
        }
      }
      /* Equal two-up variant: parent-level chooser when surfaces are peers,
         not asymmetric. */
      .surface-chooser--equal {
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto;
        grid-template-areas: none;
      }
      .surface-chooser--equal > a,
      .surface-chooser--equal > a.alt-a,
      .surface-chooser--equal > a.alt-b,
      .surface-chooser--equal > a.primary {
        grid-area: auto;
        padding: 1.75rem 2rem;
        gap: 0.625rem;
      }
      .surface-chooser--equal .name {
        font-size: 1.25rem;
        letter-spacing: -0.015em;
      }
      @media (max-width: 640px) {
        .surface-chooser--equal {
          grid-template-columns: 1fr;
        }
      }
      .surface-chooser > a {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        padding: 1.5rem 1.75rem;
        background-color: var(--color-bgRaised);
        text-decoration: none;
        transition: background-color 200ms ease;
        min-width: 0;
      }
      .surface-chooser > a.primary {
        grid-area: primary;
        padding: 2rem 2.25rem;
        gap: 0.75rem;
      }
      .surface-chooser > a.alt-a { grid-area: alt-a; }
      .surface-chooser > a.alt-b { grid-area: alt-b; }
      .surface-chooser > a:hover {
        background-color: var(--color-fillBrand-weak);
      }
      .surface-chooser > a:focus-visible {
        outline: 2px solid var(--color-strokeBrand-strong);
        outline-offset: -2px;
        position: relative;
        z-index: 1;
      }
      .surface-chooser .label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-textWeak);
        font-weight: 500;
      }
      .surface-chooser .name {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--color-textStrong);
        letter-spacing: -0.01em;
      }
      .surface-chooser > a.primary .name {
        font-size: 1.5rem;
        letter-spacing: -0.02em;
      }
      .surface-chooser .when {
        font-size: 0.875rem;
        color: var(--color-textWeak);
        line-height: 1.55;
      }
      .surface-chooser > a.primary .when {
        font-size: 1rem;
        max-width: 32rem;
      }
      .surface-chooser .footer {
        margin-top: auto;
        padding-top: 1rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-textBrand-strong);
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }
      .surface-chooser > a:hover .footer i {
        transform: translateX(2px);
      }
      .surface-chooser .footer i {
        transition: transform 200ms ease;
        font-size: 0.75rem;
      }

      /* ── Section pathway: numbered editorial nav, replaces card grids ── */
      .pathway {
        display: flex;
        flex-direction: column;
        margin: 1.5rem 0;
        border-top: 1px solid var(--color-strokeWeak);
      }
      .pathway > a {
        display: grid;
        grid-template-columns: 2.5rem 1fr auto;
        align-items: baseline;
        gap: 1.25rem;
        padding: 1rem 0.25rem;
        border-bottom: 1px solid var(--color-strokeWeak);
        text-decoration: none;
        color: inherit;
        transition: background-color 200ms ease, padding-left 200ms ease;
      }
      .pathway > a:hover {
        background-color: var(--color-fillBrand-weak);
        padding-left: 0.75rem;
      }
      .pathway > a:focus-visible {
        outline: 2px solid var(--color-strokeBrand-strong);
        outline-offset: -2px;
      }
      .pathway .step {
        font-variant-numeric: tabular-nums;
        font-size: 0.875rem;
        color: var(--color-textWeak);
        font-weight: 500;
      }
      .pathway .title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-textStrong);
        letter-spacing: -0.01em;
      }
      .pathway .desc {
        display: block;
        font-size: 0.875rem;
        font-weight: 400;
        color: var(--color-textWeak);
        margin-top: 0.125rem;
        line-height: 1.5;
      }
      .pathway .arrow {
        color: var(--color-textWeak);
        font-size: 0.875rem;
        align-self: center;
        transition: transform 200ms ease, color 200ms ease;
      }
      .pathway > a:hover .arrow {
        color: var(--color-textBrand-strong);
        transform: translateX(2px);
      }

      /* Respect OS reduced-motion preference: keep color/background feedback,
         drop the translate animations. */
      @media (prefers-reduced-motion: reduce) {
        .surface-chooser > a,
        .surface-chooser .footer i,
        .pathway > a,
        .pathway .arrow {
          transition: none;
        }
        .pathway > a:hover {
          padding-left: 0.25rem;
        }
        .pathway > a:hover .arrow,
        .surface-chooser > a:hover .footer i {
          transform: none;
        }
      }


      .t-white { filter: brightness(0) invert(1); }
      .t-black { filter: brightness(0); }

      .callout {
        background-color: var(--color-fillBrand-weak);
        border-left: 4px solid var(--color-strokeBrand-strong);
        padding: 20px 24px;
        margin: 28px 0;
        border-radius: 8px;
        font-size: 1rem;
      }
      .callout i:first-child,
      .callout > p:first-child > i:first-child {
        font-size: 1.125rem;
        color: var(--color-fillBrand-strong);
      }
      /* Tip callouts — green semantic color */
      .callout-tip {
        border-left-color: oklch(0.65 0.2 145);
        background-color: oklch(0.97 0.02 145);
      }
      .callout-tip i:first-child,
      .callout-tip > p:first-child > i:first-child {
        color: oklch(0.55 0.2 145);
      }
      /* Warning callouts — amber */
      .callout-warning {
        border-left-color: oklch(0.75 0.17 70);
        background-color: oklch(0.97 0.02 70);
      }
      .callout-warning i:first-child,
      .callout-warning > p:first-child > i:first-child {
        color: oklch(0.65 0.17 70);
      }

      .callout p:first-of-type {
        margin-top: 5px;
      }

      .callout ol:first-of-type {
        margin-top: 5px;
      }

      .callout p svg {
        margin-right: 5px;
      }

      .callout-red {
        border-left: 6px solid oklch(0.6 0.24 25) !important;
        background-color: oklch(0.97 0.02 25);
      }
      [data-theme='dark'] .callout-red {
        background-color: oklch(0.22 0.04 25);
        border-left-color: oklch(0.65 0.2 25) !important;
      }

      [data-theme='dark'] .callout {
        background-color: var(--color-fillAlternate);
        color: var(--color-textStrong);
      }
      [data-theme='dark'] .callout code {
        background: var(--color-fillRaised);
      }
      [data-theme='dark'] .callout-tip {
        background-color: oklch(0.22 0.04 145);
        border-left-color: oklch(0.65 0.18 145);
      }
      [data-theme='dark'] .callout-tip i:first-child,
      [data-theme='dark'] .callout-tip > p:first-child > i:first-child {
        color: oklch(0.72 0.18 145);
      }
      [data-theme='dark'] .callout-warning {
        background-color: oklch(0.22 0.04 70);
        border-left-color: oklch(0.75 0.15 70);
      }
      [data-theme='dark'] .callout-red {
        background-color: oklch(0.22 0.04 25);
        border-left-color: oklch(0.65 0.2 25) !important;
      }
      @media (prefers-color-scheme: dark) {
        .callout-tip {
          background-color: oklch(0.22 0.04 145);
          border-left-color: oklch(0.65 0.18 145);
        }
        .callout-tip i:first-child,
        .callout-tip > p:first-child > i:first-child {
          color: oklch(0.72 0.18 145);
        }
        .callout-warning {
          background-color: oklch(0.22 0.04 70);
          border-left-color: oklch(0.75 0.15 70);
        }
        .callout-red {
          background-color: oklch(0.22 0.04 25);
          border-left-color: oklch(0.65 0.2 25) !important;
        }
      }

      .docs-table table thead tr th {
        font-weight: 600;
        text-align: left;
        padding: 12px;
        color: var(--color-textStrong);
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .docs-table {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        margin-top: 1.25em;
        margin-bottom: 1.75em;
      }

      .docs-table table {
        border: 1px solid var(--color-strokeWeak);
        border-radius: 8px;
        overflow: hidden;
        min-width: 600px;
      }

      .docs-table table thead {
        background-color: var(--color-fillWeak);
      }

      .docs-table table thead tr th:first-child {
        border-right: 1px solid var(--color-strokeWeak);
      }

      .docs-table table tbody tr td:first-child {
        border-right: 1px solid var(--color-strokeWeak);
        font-weight: 500;
        color: var(--color-textStrong);
      }

      .docs-table table tbody tr:nth-child(even) {
        background-color: var(--color-fillWeak);
      }
      .docs-table table tbody tr:hover {
        background-color: var(--color-fillBrand-weak);
      }

      .docs-table table tbody tr td {
        vertical-align: middle !important;
        padding: 12px;
        color: var(--color-textWeak);
        font-size: 1.0625rem;
        line-height: 1.6;
      }
      .docs-table table tbody tr td code {
        font-size: 0.8125rem;
        padding: 2px 6px;
        background: var(--color-fillWeak);
        border-radius: 4px;
        white-space: nowrap;
      }

      .btn {
        text-decoration: none !important;
      }
      #mainArticle .btn.btn-outline {
        border-color: var(--color-strokeWeak);
        color: var(--color-textWeak);
        font-weight: 500;
      }
      #mainArticle .btn.btn-outline:hover {
        border-color: var(--color-strokeBrand-weak);
        color: var(--color-textStrong);
        background-color: var(--color-fillBrand-weak);
      }

      /* DO NOT REMOVE - integration-footer.liquid images */
      button img,
      #sdk-images img {
        border-width: 0px !important;
        --tw-drop-shadow: none !important;
      }

      /* Styling for tabs component */
      .tab-button {
        padding: 12px 24px;
        cursor: pointer;
        border: 1px solid var(--color-strokeWeak);
        border-bottom: none;
        border-radius: 8px 8px 0 0;
        margin-right: 8px;
        background-color: var(--color-fillRaised);
        color: var(--color-text);
        font-weight: 500;
        transition: all 0.2s ease;
      }
      .tab-button:hover {
        background-color: var(--color-fillBrand-weak);
        color: var(--color-textStrong);
      }
      .tab-button.active {
        background-color: var(--color-bgBase);
        border-bottom: 2px solid var(--color-bgBase);
        border-top: 2px solid var(--color-strokeBrand-strong);
        color: var(--color-textBrand-strong);
        font-weight: 600;
      }
      .tab-content {
        padding: 24px;
        border: 1px solid var(--color-strokeWeak);
        border-radius: 0 8px 8px 8px;
        background-color: var(--color-bgBase);
      }
      .tab-content.active {
        display: block;
      }

      .faq-answer a {
        color: var(--color-textBrand-strong);
        text-decoration: underline;
      }

      /* Code block header with language label + copy button */
      .code-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 16px;
        background: #282c34;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px 12px 0 0;
        font-size: 0.75rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
      }
      .code-header + code { border-radius: 0 0 12px 12px !important; }
      .code-lang {
        color: #7f848e; text-transform: uppercase; letter-spacing: 0.05em;
        display: flex; align-items: center; gap: 6px;
      }
      .code-lang::before {
        content: '';
        width: 8px; height: 8px; border-radius: 50%;
        background: #7f848e;
        flex-shrink: 0;
      }
      .code-lang[data-lang="go"]::before { background: oklch(0.72 0.13 195); }
      .code-lang[data-lang="javascript"]::before,
      .code-lang[data-lang="js"]::before,
      .code-lang[data-lang="jsx"]::before,
      .code-lang[data-lang="typescript"]::before,
      .code-lang[data-lang="ts"]::before { background: oklch(0.78 0.15 85); }
      .code-lang[data-lang="python"]::before { background: oklch(0.72 0.14 250); }
      .code-lang[data-lang="php"]::before { background: oklch(0.60 0.16 290); }
      .code-lang[data-lang="ruby"]::before { background: oklch(0.60 0.2 25); }
      .code-lang[data-lang="sh"]::before,
      .code-lang[data-lang="bash"]::before,
      .code-lang[data-lang="shell"]::before { background: oklch(0.72 0.18 145); }
      .code-lang[data-lang="java"]::before { background: oklch(0.65 0.18 40); }
      .code-lang[data-lang="csharp"]::before,
      .code-lang[data-lang="cs"]::before { background: oklch(0.58 0.2 300); }
      .code-lang[data-lang="elixir"]::before { background: oklch(0.58 0.18 310); }
      .code-lang[data-lang="yaml"]::before,
      .code-lang[data-lang="json"]::before,
      .code-lang[data-lang="toml"]::before { background: oklch(0.70 0.10 60); }
      .code-copy {
        display: flex; align-items: center; gap: 6px;
        color: #7f848e; background: none; border: none;
        cursor: pointer; font-size: 0.75rem; padding: 2px 8px;
        border-radius: 4px; transition: all 150ms ease;
      }
      .code-copy:hover { color: #abb2bf; background: rgba(255,255,255,0.08); }
      .code-copy.copied { color: #98c379; }

      /* AI Context Menu */
      .ai-menu-wrap { position: relative; }
      .ai-menu {
        position: absolute; right: 0; top: 100%; z-index: 50;
        min-width: 260px; margin-top: 6px;
        background: var(--color-bgRaised); border: 1px solid var(--color-strokeWeak);
        border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        padding: 6px; opacity: 0; transform: scale(0.95) translateY(-4px);
        pointer-events: none; transition: opacity 150ms ease, transform 150ms ease;
      }
      .ai-menu.open { opacity: 1; transform: scale(1) translateY(0); pointer-events: auto; }
      .ai-menu-item {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 12px; border-radius: 8px; cursor: pointer;
        font-size: 0.8125rem; color: var(--color-text); text-decoration: none;
        border: none; background: none; width: 100%; text-align: left;
        transition: background 100ms ease;
      }
      .ai-menu-item:hover { background: var(--color-fillWeak); }
      .ai-menu-item.disabled {
        opacity: 0.4; pointer-events: none;
      }
      .ai-menu-item svg { width: 16px; height: 16px; flex-shrink: 0; }
      .ai-menu-item .ai-menu-label { flex: 1; }
      .ai-menu-item .ai-menu-sub { font-size: 0.6875rem; color: var(--color-textWeak); }
      .ai-menu-sep { height: 1px; background: var(--color-strokeWeak); margin: 4px 8px; }
      .ai-menu-item .ai-menu-check {
        display: none; color: oklch(0.65 0.2 145);
      }
      .ai-menu-item.copied .ai-menu-check { display: block; }
      .ai-menu-item.copied svg:first-child { display: none; }

      /* Sidebar collapsible sections */
      .sidebar-section summary { list-style: none; cursor: pointer; }
      .sidebar-section summary::-webkit-details-marker { display: none; }
      .sidebar-section summary .chevron-icon {
        transition: transform 200ms ease;
        width: 12px; height: 12px; flex-shrink: 0;
      }
      .sidebar-section[open] summary .chevron-icon { transform: rotate(90deg); }

      /* Breadcrumbs */
      .breadcrumbs {
        font-size: 0.875rem;
        display: flex; flex-wrap: wrap; align-items: center; gap: 0;
      }
      .breadcrumbs a { color: var(--color-textWeak); text-decoration: none; white-space: nowrap; }
      .breadcrumbs a:hover { color: var(--color-textBrand-strong); }
      .breadcrumbs .separator { color: var(--color-textWeak); opacity: 0.4; margin: 0 8px; }
      .breadcrumbs .current { color: var(--color-textStrong); font-weight: 500; white-space: nowrap; }
      @media (max-width: 640px) { .breadcrumbs { display: none; } }

      /* Prev/Next navigation */
      .prev-next-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; max-width: 36rem; margin-left: auto; margin-right: auto; }
      @media (max-width: 640px) { .prev-next-nav { grid-template-columns: 1fr; max-width: none; } }
      .prev-next-card {
        display: flex; flex-direction: column; padding: 0.875rem 1.25rem;
        border: 1px solid var(--color-strokeWeak); border-radius: 10px;
        text-decoration: none; transition: border-color 200ms ease, box-shadow 200ms ease;
        background: var(--color-bgRaised);
        text-align: left;
      }
      .prev-next-card:hover {
        border-color: var(--color-strokeBrand-weak);
        box-shadow: 0 2px 8px 0 rgba(0,0,0,0.06);
      }
      .prev-next-card .direction {
        font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em;
        color: var(--color-textWeak); margin-bottom: 2px;
      }
      .prev-next-card .title { color: var(--color-textBrand-strong); font-weight: 500; font-size: 0.9rem; }
      .prev-next-card.next { text-align: right; grid-column: 2; }
      @media (max-width: 640px) { .prev-next-card.next { grid-column: 1; } }
    </style>

